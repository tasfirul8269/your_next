# ==================== APPLICATION ====================
APP_NAME="Next Outfit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_ADMIN_URL=admin
APP_TIMEZONE=Asia/Dhaka
APP_LOCALE=en
APP_CURRENCY=BDT

# ==================== DATABASE (Local MySQL) ====================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nextoutfit_ecom
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=

# ==================== FILESYSTEM ====================
FILESYSTEM_DISK=local

# ==================== CLOUDINARY (Image Hosting) ====================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ==================== REDIS ====================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==================== SESSION & CACHE ====================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=nextoutfit_

# ==================== SSLCOMMERZ ====================
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWORD=
SSLCZ_TESTMODE=true

# ==================== MAIL ====================
MAIL_MAILER=log
MAIL_FROM_ADDRESS=test@nextoutfit.local
MAIL_FROM_NAME="Next Outfit Test"

# ==================== SSL WIRELESS (SMS OTP) ====================
SSLWIRELESS_MOCK=true
SSLWIRELESS_SID=
SSLWIRELESS_API_TOKEN=
SSLWIRELESS_URL=https://isms.gennet.com.bd/api/v3/send-sms
